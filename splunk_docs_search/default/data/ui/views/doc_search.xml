<form version="1.1" theme="light" script="pdf_viewer.js" stylesheet="doc_search.css">
  <label>Splunk Docs Search</label>
  <description>Search the full Splunk documentation set, filter by product, and read the whole page as a PDF inline.</description>

  <fieldset submitButton="false" autoRun="true">
    <input type="text" token="kw" searchWhenChanged="true">
      <label>Keywords</label>
      <default>*</default>
      <initialValue>*</initialValue>
    </input>
    <input type="dropdown" token="cat" searchWhenChanged="true">
      <label>Product</label>
      <choice value="*">All products</choice>
      <default>*</default>
      <fieldForLabel>category</fieldForLabel>
      <fieldForValue>category</fieldForValue>
      <search>
        <query>index=splunk_docs | stats count by category | sort - count | fields category</query>
        <earliest>0</earliest>
        <latest></latest>
      </search>
      <!-- reset the version filter when the product changes -->
      <change>
        <set token="ver">*</set>
      </change>
    </input>
    <input type="dropdown" token="ctype" searchWhenChanged="true">
      <label>Content type</label>
      <choice value="*">All types</choice>
      <default>*</default>
      <fieldForLabel>content_type</fieldForLabel>
      <fieldForValue>content_type</fieldForValue>
      <search>
        <query>index=splunk_docs | stats count by content_type | sort - count | fields content_type</query>
        <earliest>0</earliest>
        <latest></latest>
      </search>
    </input>
    <input type="dropdown" token="ver" searchWhenChanged="true">
      <label>Version</label>
      <choice value="*">All versions</choice>
      <default>*</default>
      <fieldForLabel>version</fieldForLabel>
      <fieldForValue>version</fieldForValue>
      <!-- versions cascade from the selected Product -->
      <search>
        <query>index=splunk_docs category=$cat|s$ version=* | stats count by version | sort - version | fields version</query>
        <earliest>0</earliest>
        <latest></latest>
      </search>
    </input>
  </fieldset>

  <row>
    <panel>
      <html>
        <div class="sds-counts">
          <span class="sds-chip">Total pages: <strong id="sds-total">–</strong></span>
        </div>
      </html>
    </panel>
  </row>

  <row>
    <!-- LEFT: results list -->
    <panel>
      <title>Documentation pages — click a row to read it</title>
      <table>
        <search>
          <query>
index=splunk_docs $kw$
| eval category=if(isnull(category) OR category="","Other",category)
| eval content_type=if(isnull(content_type) OR content_type="","Other",content_type)
| eval version=if(isnull(version) OR version="","—",version)
| search category=$cat|s$ content_type=$ctype|s$ version=$ver|s$
| eval updated=strftime(_time,"%Y-%m-%d")
| table category title version content_type updated pdf_file url
| sort category title
          </query>
          <earliest>0</earliest>
          <latest></latest>
        </search>
        <option name="count">20</option>
        <option name="drilldown">row</option>
        <option name="wrap">true</option>
        <option name="rowNumbers">false</option>
        <fields>["category","title","version","content_type","updated"]</fields>
        <drilldown>
          <set token="pdf_file">$row.pdf_file$</set>
          <set token="doc_title">$row.title$</set>
          <set token="doc_url">$row.url$</set>
        </drilldown>
      </table>
    </panel>

    <!-- RIGHT: embedded PDF reader (populated by pdf_viewer.js) -->
    <panel>
      <title>Reader</title>
      <html>
        <div id="pdf-toolbar">
          <span id="pdf-title">Select a document to read</span>
          <a id="pdf-open" href="$doc_url$" target="_blank" rel="noopener">Open live page ↗</a>
        </div>
        <div id="pdfview">
          <div class="pdf-empty">Select a document in the list to view its full PDF here.</div>
        </div>
      </html>
    </panel>
  </row>
</form>
